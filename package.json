{
  "name": "dch-sporplanlaegger",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-preview.mjs",
    "dev:next": "next dev",
    "build": "node scripts/build-preview.mjs",
    "build:next": "next build",
    "demo:check": "node scripts/check-preview.mjs",
    "start": "node scripts/dev-preview.mjs --no-watch",
    "lint": "node scripts/lint-source.mjs",
    "typecheck": "tsc -p tsconfig.geometry.json --noEmit --pretty false && tsc -p tsconfig.store.json --noEmit --pretty false && tsc -p tsconfig.project-repository.json --noEmit --pretty false && tsc -p tsconfig.schema.json --noEmit --pretty false && tsc -p tsconfig.ui.json --noEmit --pretty false && tsc -p tsconfig.api.json --noEmit --pretty false",
    "test": "tsx scripts/run-domain-tests.ts",
    "test:vitest": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:generate:postgres": "prisma generate --schema prisma/schema.postgresql.prisma",
    "db:migrate": "prisma db execute --file prisma/migrations/20260721112000_init/migration.sql --schema prisma/schema.prisma",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgresql.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "format": "prettier --check ."
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@turf/turf": "7.2.0",
    "clsx": "2.1.1",
    "html-to-image": "1.11.13",
    "jspdf": "4.2.1",
    "leaflet": "1.9.4",
    "lucide-react": "0.468.0",
    "next": "15.5.20",
    "proj4": "2.12.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "2.6.0",
    "zod": "3.24.1",
    "zustand": "5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/leaflet": "1.9.16",
    "@types/node": "20.17.10",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.20",
    "jsdom": "25.0.1",
    "postcss": "8.5.10",
    "prettier": "3.4.2",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.17",
    "tsx": "4.23.1",
    "typescript": "5.6.3",
    "vitest": "3.2.6"
  },
  "overrides": {
    "postcss": "8.5.10",
    "vite": "6.4.3"
  }
}
